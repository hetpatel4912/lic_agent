@{
    ViewData["Title"] = "Home Page";
}

<section class="hero" id="home">
  <div class="hero-copy">
    <p class="eyebrow">Trusted LIC policy guidance</p>
    <h1>Simple insurance support for families, savings, and future planning.</h1>
    <p>
      Meet your local LIC advisor for policy selection, premium reminders,
      claims assistance, nomination updates, and long-term financial planning.
    </p>
    <div class="hero-actions">
      <a class="button primary" href="#contact">Send Enquiry</a>
      <a class="button secondary" href="tel:+918490943582">Call Agent</a>
    </div>
  </div>

  <div class="hero-panel" aria-label="Agent profile summary">
    <div class="agent-photo">
      <img src="/images/amit.png" alt="">
    </div>
    <div>
      <p class="agent-title">Your LIC Agent</p>
      <h2>Amit Patel</h2>
      <p>Policy advisor and customer service support</p>
    </div>
    <dl class="quick-info">
      <div>
        <dt>Experience</dt>
        <dd>5+ Years</dd>
      </div>
      <div>
        <dt>Support</dt>
        <dd>Policy, claim, renewal</dd>
      </div>
    </dl>
  </div>
</section>

<section class="section" id="policies">
  <div class="section-heading">
    <p class="eyebrow">LIC policies</p>
    <h2>Popular policy categories</h2>
  </div>

  <div class="grid cards-3">
    <article class="card">
      <span class="icon">F</span>
      <h3>Family Protection</h3>
      <p>Life cover options to support your family during uncertain times.</p>
    </article>
    <article class="card">
      <span class="icon">C</span>
      <h3>Child Future Plans</h3>
      <p>Planning support for education, savings, and milestone goals.</p>
    </article>
    <article class="card">
      <span class="icon">R</span>
      <h3>Retirement Planning</h3>
      <p>Pension and income planning guidance for your later years.</p>
    </article>
  </div>
</section>

<section class="section split" id="services">
  <div class="section-heading">
    <p class="eyebrow">Services</p>
    <h2>Help for every policy stage</h2>
    <p>
      From choosing the right plan to keeping documents updated, get direct
      support without complicated steps.
    </p>
  </div>

  <div class="service-list">
    <div class="service-item">
      <strong>New policy consultation</strong>
      <span>Compare needs, budget, premium term, and expected benefits.</span>
    </div>
    <div class="service-item">
      <strong>Premium reminder support</strong>
      <span>Get help tracking due dates and renewal information.</span>
    </div>
    <div class="service-item">
      <strong>Claim assistance</strong>
      <span>Guidance for claim process, required forms, and documents.</span>
    </div>
    <div class="service-item">
      <strong>Policy servicing</strong>
      <span>Nomination, address change, revival, loan, and surrender support.</span>
    </div>
  </div>
</section>

<section class="section office-band" id="office">
  <div>
    <p class="eyebrow">Office address</p>
    <h2>Visit or connect directly</h2>
    <p>
        Hari Om Society 2, near Amizara Road, Opp. Umiya Mataji Temple, Bamroli, Surat, Gujarat 394210
    </p>
  </div>

  <div class="office-actions">
    <a class="button primary" href="https://maps.app.goo.gl/hbH82EfKbZzNEGx99" target="_blank" rel="noreferrer">
      Open Map
    </a>
    <a class="button secondary" href="mailto:licagentamitpatel@gmail.com">Email Agent</a>
  </div>
</section>

<section class="section contact-section" id="contact">
  <div class="contact-copy">
    <p class="eyebrow">Contact form</p>
    <h2>Send details by phone message</h2>
    <p>
      Fill the form and tap send. Your phone message app will open with a
      ready message for the LIC agent.
    </p>

    <div class="social-links" aria-label="Social media links">
      <a class="social instagram" href="https://www.instagram.com/amit_m_patel_lic/" target="_blank" rel="noreferrer" aria-label="Instagram">
        <span>Instagram</span>
      </a>
      <a class="social facebook" href="https://facebook.com/" target="_blank" rel="noreferrer" aria-label="Facebook">
        <span>Facebook</span>
      </a>
    </div>
  </div>

  <form class="contact-form" id="contactForm">
    <label>
      Full name
      <input type="text" id="name" name="name" placeholder="Enter your name" required />
    </label>
    <label>
      Mobile number
      <input type="tel" id="phone" name="phone" placeholder="Enter your mobile number" required />
    </label>
    <label>
      Interested service
      <select id="service" name="service" required>
        <option value="">Select service</option>
        <option>New LIC policy</option>
        <option>Premium payment help</option>
        <option>Claim assistance</option>
        <option>Policy update</option>
        <option>Retirement planning</option>
      </select>
    </label>
    <label>
      Message
      <textarea id="message" name="message" rows="4" placeholder="Write your message" required></textarea>
    </label>
    <button class="button primary full" type="submit">Open Message App</button>
    <p class="form-note">On desktop, SMS opening depends on your device message setup.</p>
  </form>
</section>
