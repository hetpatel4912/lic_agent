@{
    ViewData["Title"] = "Admin Dashboard";
}

<section class="admin-dashboard">
    <div class="admin-toolbar">
        <div>
            <p class="eyebrow">Policy dashboard</p>
            <h1>Premium reminder cards</h1>
        </div>
        <button class="button primary" type="button" data-bs-toggle="modal" data-bs-target="#policyModal">
            Add Policy
        </button>
    </div>

    <div class="alert d-none" id="policyMessage" role="alert"></div>
    <div class="policy-card-grid" id="policyGrid" aria-live="polite"></div>
</section>

<div class="modal fade" id="policyModal" tabindex="-1" aria-labelledby="policyModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content policy-modal">
            <div class="modal-header">
                <div>
                    <p class="eyebrow">New card</p>
                    <h2 class="modal-title" id="policyModalLabel">Add policy details</h2>
                </div>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form id="policyForm">
                <div class="modal-body policy-form-grid">
                    <label for="policyNumber">
                        Policy number
                        <input class="form-control" type="text" id="policyNumber" name="PolicyNumber" placeholder="LIC-00000000" required />
                    </label>
                    <label for="mobileNumber">
                        Mobile number
                        <input class="form-control" type="tel" id="mobileNumber" name="MobileNumber" placeholder="Enter mobile number" required />
                    </label>
                    <label for="policyHolderName">
                        Policy holder name
                        <input class="form-control" type="text" id="policyHolderName" name="PolicyHolderName" placeholder="Enter full name" required />
                    </label>
                    <label for="premiumDate">
                        Premium date
                        <input class="form-control" type="date" id="premiumDate" name="PremiumDate" required />
                    </label>
                    <label for="premiumAmount">
                        Premium amount
                        <input class="form-control" type="number" id="premiumAmount" name="PremiumAmount" placeholder="Enter amount" min="1" step="0.01" required />
                    </label>
                </div>
                <div class="modal-footer">
                    <button type="button" class="button secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="button primary" id="savePolicyButton">Save Policy</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(function () {
            const grid = $("#policyGrid");
            const form = $("#policyForm");
            const saveButton = $("#savePolicyButton");
            const message = $("#policyMessage");
            const modalElement = document.getElementById("policyModal");
            const policyModal = bootstrap.Modal.getOrCreateInstance(modalElement);

            function formatCurrency(value) {
                return Number(value).toLocaleString("en-IN", {
                    style: "currency",
                    currency: "INR",
                    maximumFractionDigits: 0
                });
            }

            function formatDate(value) {
                return new Date(value).toLocaleDateString("en-IN", {
                    day: "2-digit",
                    month: "short",
                    year: "numeric"
                });
            }

            function showMessage(text, type) {
                message
                    .removeClass("d-none alert-success alert-danger")
                    .addClass(type === "success" ? "alert-success" : "alert-danger")
                    .text(text);
            }

            function escapeHtml(value) {
                return $("<div>").text(value ?? "").html();
            }

            function policyCard(policy) {
                return `
                    <article class="policy-card">
                        <div class="policy-card-header">
                            <span>Policy No.</span>
                            <strong>${escapeHtml(policy.policyNumber)}</strong>
                        </div>
                        <div class="policy-holder">
                            <span>Policy Holder</span>
                            <strong>${escapeHtml(policy.policyHolderName)}</strong>
                        </div>
                        <dl class="policy-details">
                            <div>
                                <dt>Mobile Number</dt>
                                <dd>${escapeHtml(policy.mobileNumber)}</dd>
                            </div>
                            <div>
                                <dt>Premium Date</dt>
                                <dd>${formatDate(policy.premiumDate)}</dd>
                            </div>
                            <div>
                                <dt>Premium Amount</dt>
                                <dd>${formatCurrency(policy.premiumAmount)}</dd>
                            </div>
                        </dl>
                    </article>`;
            }

            function loadPolicies() {
                grid.html("<div class='policy-empty'>Loading policy cards...</div>");

                $.ajax({
                    url: "/Admin/Policies",
                    method: "GET",
                    success: function (policies) {
                        if (!policies.length) {
                            grid.html("<div class='policy-empty'>No policy cards added yet.</div>");
                            return;
                        }

                        grid.html(policies.map(policyCard).join(""));
                    },
                    error: function () {
                        grid.html("<div class='policy-empty'>Unable to load policy cards.</div>");
                    }
                });
            }

            form.on("submit", function (event) {
                event.preventDefault();

                if (!this.checkValidity()) {
                    this.reportValidity();
                    return;
                }

                saveButton.prop("disabled", true).text("Saving...");

                $.ajax({
                    url: "/Admin/Policies",
                    method: "POST",
                    data: form.serialize(),
                    success: function (result) {
                        showMessage(result.message || "Policy card added successfully.", "success");
                        form[0].reset();
                        policyModal.hide();
                        loadPolicies();
                    },
                    error: function (xhr) {
                        const response = xhr.responseJSON;
                        showMessage(response?.message || "Unable to save policy card.", "error");
                    },
                    complete: function () {
                        saveButton.prop("disabled", false).text("Save Policy");
                    }
                });
            });

            loadPolicies();
        });
    </script>
}
